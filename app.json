{
  "expo": {
    "name": "Gourmet Fine Pastries",
    "slug": "gourmet-pastries-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FADAD9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starkey18.gourmetpastries"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FADAD9"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.starkey18.gourmetpastries",
      "userInterfaceStyle": "light",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#CE6F79"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "299f214c-0cd2-4062-8f90-cd97f5e33d1a"
      }
    },
    "owner": "starkey1.8"
  }
}